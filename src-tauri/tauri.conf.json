{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hq-installer",
  "version": "0.1.0",
  "identifier": "ai.indigo.hq-installer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HQ Installer",
        "width": 960,
        "height": 700,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Install HQ without opening a terminal",
    "longDescription": "HQ Installer is a native macOS app that walks non-technical users through installing HQ: system dependency checks, template scaffolding, optional cloud sync, and handoff to Claude Code.",
    "copyright": "Copyright © 2026 Indigo. All rights reserved.",
    "publisher": "Indigo",
    "homepage": "https://github.com/indigoai-us/hq-installer",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "frameworks": []
    }
  }
}
