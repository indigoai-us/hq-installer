{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hq-installer",
  "version": "0.1.0",
  "identifier": "ai.indigo.hq-installer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HQ Installer",
        "width": 900,
        "height": 640,
        "resizable": false,
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../templates": "templates"
    },
    "macOS": {
      "minimumSystemVersion": "13.0",
      "hardenedRuntime": true,
      "entitlements": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["hq-installer"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk=",
      "endpoints": ["https://updates.hq-installer.getindigo.ai/latest.json"]
    }
  }
}
