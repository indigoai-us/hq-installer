{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hq-installer",
  "version": "0.1.25",
  "identifier": "ai.indigo.hq-installer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "HQ Installer",
        "width": 960,
        "height": 640,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../templates": "templates"
    },
    "macOS": {
      "minimumSystemVersion": "13.0",
      "hardenedRuntime": true,
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYwQ0VBRkNEREU0RUM2NEEKUldSS3hrN2V6YS9PWUlDZE10R3Rkek1tNVk0SmtrZ0pZcGk1MVFBeXVZRHBVL1R6UVRCMVhJeHoK",
      "endpoints": [
        "https://github.com/indigoai-us/hq-installer/releases/latest/download/latest.json"
      ]
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
