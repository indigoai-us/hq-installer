{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.gnupg/**)",
      "Read(~/.env)",
      "Read(~/.netrc)"
    ]
  },
  "env": {
    "MAX_THINKING_TOKENS": "31999",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  }
}
