---
import { fetchLatestRelease, formatBytes, formatDate } from "../lib/release.ts";

// Runs on every ISR revalidation (hourly). Rendered HTML is cached by
// Vercel — fresh visitors get a cache hit until the TTL expires.
const release = await fetchLatestRelease();

const aarch64Url = release?.dmgAarch64?.browserDownloadUrl ?? null;
const x64Url = release?.dmgX64?.browserDownloadUrl ?? null;
const aarch64Size = release?.dmgAarch64 ? formatBytes(release.dmgAarch64.size) : null;
const x64Size = release?.dmgX64 ? formatBytes(release.dmgX64.size) : null;
const universalUrl = release?.macUniversal?.asset.browserDownloadUrl ?? null;
const universalSize = release?.macUniversal ? formatBytes(release.macUniversal.asset.size) : null;
const universalFormat = release?.macUniversal?.format ?? null;
// v0.1.11 shipped .dmg; v0.1.12+ ships .zip (Safari auto-extracts, no
// drag-to-Applications). When a universal artifact is present we render
// one primary button instead of the old arch-split pair. The subtitle
// shows the distribution format so users know what they're getting.
const showUniversal = Boolean(universalUrl);
// Format-specific subtitle copy. Each arm stays short enough to fit in
// the secondary slot on mobile (btn-os line, ~36ch).
const universalSubtitle = universalFormat === "zip"
  ? "Universal · Notarized .zip — opens on double-click"
  : universalFormat === "dmg"
    ? "Universal · Notarized .dmg — Apple Silicon + Intel"
    : universalFormat === "app.tar.gz"
      ? "Universal · Notarized .app.tar.gz (advanced)"
      : "Universal · Apple Silicon + Intel";
const releaseDate = release ? formatDate(release.publishedAt) : null;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="HQ — Personal OS for orchestrating work across companies, workers, and AI. Download the native macOS installer." />
    <meta name="theme-color" content="#09090b" />
    <title>HQ — Download</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><text y='50' font-size='48'>HQ</text></svg>" />
    <link rel="canonical" href="https://install.getindigo.ai" />
    <meta property="og:title" content="HQ — Download" />
    <meta property="og:description" content="Personal OS for orchestrating work across companies, workers, and AI." />
    <meta property="og:type" content="website" />

    <!--
      goclaw-admin pack fonts — Barlow Condensed (display),
      Inter (body), IBM Plex Mono (numerals). Loaded via Google
      Fonts; preconnect reduces TTFB on the font stylesheet.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700&family=Inter:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <main class="root">
      <header class="hero">
        <div class="logo">HQ</div>
        <h1>Your own personal OS for getting things done.</h1>
        <p class="tagline">
          Orchestrate work across companies, workers, and AI — from one place,
          on your machine, with Claude Code driving.
        </p>
      </header>

      <section class="download-card" aria-labelledby="download-heading">
        <h2 id="download-heading">Download HQ Installer</h2>

        {release ? (
          <div class="release-meta">
            <span class="tag">{release.tag}</span>
            <span class="published">Released {releaseDate}</span>
          </div>
        ) : (
          <div class="release-meta release-meta--pending">
            <span class="tag tag--pending">coming soon</span>
            <span class="published">The first public release is being prepared.</span>
          </div>
        )}

        <div class="buttons" id="buttons">
          {showUniversal ? (
            <a
              id="btn-universal"
              class="btn btn-primary"
              href={universalUrl ?? "#"}
              data-arch="universal"
              aria-disabled={!universalUrl}
              data-state={universalUrl ? "ready" : "pending"}
            >
              <span class="btn-arch">Download for macOS</span>
              <span class="btn-os">{universalSubtitle}</span>
              {universalSize && <span class="btn-size">{universalSize}</span>}
            </a>
          ) : (
            <>
              <a
                id="btn-aarch64"
                class="btn btn-primary"
                href={aarch64Url ?? "#"}
                data-arch="aarch64"
                aria-disabled={!aarch64Url}
                data-state={aarch64Url ? "ready" : "pending"}
              >
                <span class="btn-arch">Apple Silicon</span>
                <span class="btn-os">macOS · M1 / M2 / M3 / M4</span>
                {aarch64Size && <span class="btn-size">{aarch64Size}</span>}
              </a>

              <a
                id="btn-x64"
                class="btn btn-secondary"
                href={x64Url ?? "#"}
                data-arch="x64"
                aria-disabled={!x64Url}
                data-state={x64Url ? "ready" : "pending"}
              >
                <span class="btn-arch">Intel Mac</span>
                <span class="btn-os">macOS · x86_64</span>
                {x64Size && <span class="btn-size">{x64Size}</span>}
              </a>
            </>
          )}
        </div>

        <p class="os-hint" id="os-hint" aria-live="polite"></p>

        <p class="also">
          Also available for:
          <span class="soon">Windows (soon)</span> ·
          <span class="soon">Linux (soon)</span>
        </p>

        <p class="security-note">
          Signed with Indigo's Apple Developer ID and notarized by Apple.
          No Gatekeeper warnings.
        </p>
      </section>

      <section class="devs" aria-labelledby="devs-heading">
        <h3 id="devs-heading">For developers</h3>
        <p>
          Comfortable in a terminal? Skip the installer and bootstrap HQ with
          one command:
        </p>
        <pre class="code"><code>npx create-hq</code></pre>
      </section>

      <footer class="footer">
        <p>
          {release ? (
            <a href={release.htmlUrl}>View all releases on GitHub →</a>
          ) : (
            <a href="https://github.com/indigoai-us/hq-installer">View the source on GitHub →</a>
          )}
        </p>
        <p class="copyright">© 2026 Indigo. HQ is open source.</p>
      </footer>
    </main>

    <script is:inline>
      // OS detection — client-side only. Runs after HTML is cached, so
      // ISR doesn't need to re-render per-visitor. We enhance the
      // already-rendered download buttons with an emphasized state +
      // an inline hint above the buttons.
      (function () {
        try {
          const ua = navigator.userAgent || "";
          // navigator.platform is deprecated in the spec but still the
          // only cross-browser path for OS detection on Safari, where
          // navigator.userAgentData does not exist. We keep both.
          /** @type {{ platform?: string }} */
          const nav = /** @type {unknown} */ (navigator);
          const platform = nav.platform || "";

          const isMac = /Mac/i.test(platform) || /Mac/i.test(ua);
          const isWindows = /Win/i.test(platform) || /Windows/i.test(ua);
          const isLinux = /Linux/i.test(platform) || /Linux/i.test(ua);

          // Modern AS Macs report "MacIntel" in platform, but we can
          // still infer Apple Silicon via the "Mac OS X" token in UA
          // combined with a WebKit device memory probe. Browsers try
          // to hide this — fallback is to highlight aarch64 since that's
          // ~80% of new Macs sold and the safer default.
          const isAppleSilicon = (() => {
            if (!isMac) return false;
            // Chrome 91+ ships navigator.userAgentData — arm64 reports
            // architecture "arm" here.
            const uaData = /** @type {{architecture?: string}} */ (
              /** @type {unknown} */ (navigator).userAgentData
            );
            if (uaData && uaData.architecture) {
              return uaData.architecture === "arm";
            }
            // Fallback: default to aarch64 for any Mac newer than 2020.
            return true;
          })();

          const hint = document.getElementById("os-hint");
          const btnA = document.getElementById("btn-aarch64");
          const btnX = document.getElementById("btn-x64");
          const btnU = document.getElementById("btn-universal");

          if (isMac) {
            if (btnU) {
              // Universal build — one button, always featured on Mac.
              btnU.classList.add("btn-featured");
              hint && (hint.textContent = isAppleSilicon
                ? "Detected: macOS on Apple Silicon — this universal build runs natively."
                : "Detected: macOS on Intel — this universal build runs natively.");
            } else if (isAppleSilicon) {
              btnA && btnA.classList.add("btn-featured");
              hint && (hint.textContent = "Detected: macOS on Apple Silicon — the top button is the one you want.");
            } else {
              btnX && btnX.classList.add("btn-featured");
              hint && (hint.textContent = "Detected: macOS on Intel — use the Intel Mac button.");
            }
          } else if (isWindows) {
            hint && (hint.textContent = "Detected: Windows. Native installer coming soon — for now, try npx create-hq.");
            btnA && btnA.classList.add("btn-dim");
            btnX && btnX.classList.add("btn-dim");
            btnU && btnU.classList.add("btn-dim");
          } else if (isLinux) {
            hint && (hint.textContent = "Detected: Linux. Native installer coming soon — for now, try npx create-hq.");
            btnA && btnA.classList.add("btn-dim");
            btnX && btnX.classList.add("btn-dim");
            btnU && btnU.classList.add("btn-dim");
          }
        } catch {
          // Silently no-op on any runtime error — the static HTML still
          // works fine without JS.
        }
      })();
    </script>

    <!--
      Pack tokens (`--ga-*`) — copied from
      knowledge/public/design-styles/packs/goclaw-admin/design-tokens.css
      Do not symlink across repo boundaries (Vercel build constraint).
    -->
    <style>@import "../styles/goclaw-admin-tokens.css";</style>

    <style>
      /* ──────────────────────────────────────────────────────────────
         hq-installer download page — goclaw-admin consumer
         Flat corners. Hairline rules. Status-only color. Barlow
         Condensed display / Inter body / IBM Plex Mono numerals.
         ────────────────────────────────────────────────────────────── */

      * {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--ga-zinc-950);
        color: var(--ga-fg);
        font-family: var(--ga-font-sans);
        font-size: var(--ga-text-sm);
        letter-spacing: var(--ga-tracking-body);
        -webkit-font-smoothing: antialiased;
      }

      /* Focus rings — keyboard a11y floor, pack quality-gate item */
      a:focus-visible,
      button:focus-visible,
      [tabindex]:focus-visible {
        outline: 1px solid var(--ga-fg-muted);
        outline-offset: 2px;
      }

      .root {
        max-width: 640px;
        margin: 0 auto;
        padding: 72px 24px 80px;
      }

      /* ── Hero ───────────────────────────────────────── */
      .hero {
        text-align: center;
        margin-bottom: 56px;
      }

      .logo {
        font-family: var(--ga-font-display);
        font-weight: 700;
        font-size: 42px;
        letter-spacing: 0.15em;
        color: var(--ga-fg-strong);
        text-transform: uppercase;
        margin-bottom: 28px;
        line-height: 1;
      }

      .hero h1 {
        font-family: var(--ga-font-sans);
        font-size: 30px;
        line-height: 1.2;
        margin: 0 0 16px;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--ga-fg-strong);
      }

      .tagline {
        font-size: var(--ga-text-base);
        color: var(--ga-fg-muted);
        line-height: 1.55;
        margin: 0 auto;
        max-width: 520px;
      }

      /* ── Download card ──────────────────────────────── */
      /* No rounded corners. No fill. Hairline border only. */
      .download-card {
        background: transparent;
        border: 1px solid var(--ga-rule-6);
        border-radius: var(--ga-radius-0);
        padding: 28px 24px 24px;
        margin-bottom: 28px;
      }

      .download-card h2 {
        font-family: var(--ga-font-display);
        font-size: var(--ga-text-9);
        font-weight: 600;
        letter-spacing: var(--ga-tracking-section);
        text-transform: uppercase;
        color: var(--ga-fg-dim);
        margin: 0 0 16px;
      }

      .release-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        font-size: var(--ga-text-12);
        color: var(--ga-fg-muted);
      }

      /* Status badges — info (ready) / warning (pending).
         Flat rectangles, not pills. */
      .tag {
        display: inline-flex;
        align-items: center;
        padding: 3px 8px;
        border-radius: var(--ga-radius-0);
        background: var(--ga-accent-info-bg);
        color: var(--ga-accent-info-fg);
        font-family: var(--ga-font-mono);
        font-size: var(--ga-text-10);
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .tag--pending {
        background: var(--ga-accent-warning-bg);
        color: var(--ga-accent-warning-fg);
      }

      .published {
        font-family: var(--ga-font-mono);
        font-size: var(--ga-text-10);
        color: var(--ga-fg-dim);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      /* ── Buttons ────────────────────────────────────── */
      .buttons {
        display: grid;
        grid-template-columns: 1fr;
        gap: 8px;
      }

      .btn {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 18px;
        border: 1px solid var(--ga-rule-6);
        border-radius: var(--ga-radius-0);
        text-decoration: none;
        color: var(--ga-fg);
        background: transparent;
        transition: background 150ms, border-color 150ms;
      }

      .btn:hover {
        background: var(--ga-rule-3);
        border-color: var(--ga-rule-8);
      }

      .btn[aria-disabled="true"] {
        opacity: 0.4;
        pointer-events: none;
      }

      /* Active-row treatment (pack implementation.md §4): inset
         fill at rule-6 alpha. No colored glow. No brand accent. */
      .btn-featured {
        background: var(--ga-rule-6);
        border-color: var(--ga-rule-8);
        color: var(--ga-fg-strong);
      }

      .btn-dim {
        opacity: 0.5;
      }

      .btn-arch {
        font-family: var(--ga-font-display);
        font-weight: 600;
        font-size: var(--ga-text-base);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        flex: 1;
      }

      .btn-os {
        font-size: var(--ga-text-12);
        color: var(--ga-fg-muted);
      }

      .btn-size {
        font-family: var(--ga-font-mono);
        font-size: var(--ga-text-10);
        color: var(--ga-fg-dim);
        letter-spacing: 0.02em;
      }

      .os-hint {
        margin: 16px 0 0;
        font-size: var(--ga-text-12);
        color: var(--ga-fg-muted);
        min-height: 18px;
      }

      .also {
        margin: 24px 0 8px;
        font-size: var(--ga-text-12);
        color: var(--ga-fg-muted);
      }

      .soon {
        color: var(--ga-fg-dim);
        font-family: var(--ga-font-mono);
        font-size: var(--ga-text-10);
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .security-note {
        margin: 16px 0 0;
        font-size: var(--ga-text-12);
        color: var(--ga-fg-muted);
        line-height: 1.5;
      }

      /* ── Dev path ───────────────────────────────────── */
      .devs {
        background: transparent;
        border: 1px solid var(--ga-rule-6);
        border-radius: var(--ga-radius-0);
        padding: 20px 22px;
        margin-bottom: 48px;
      }

      .devs h3 {
        font-family: var(--ga-font-display);
        font-size: var(--ga-text-9);
        font-weight: 600;
        letter-spacing: var(--ga-tracking-section);
        text-transform: uppercase;
        color: var(--ga-fg-dim);
        margin: 0 0 12px;
      }

      .devs p {
        margin: 0 0 14px;
        font-size: var(--ga-text-sm);
        color: var(--ga-fg-muted);
        line-height: 1.55;
      }

      .code {
        background: var(--ga-zinc-900);
        border: 1px solid var(--ga-rule-6);
        border-radius: var(--ga-radius-0);
        padding: 12px 14px;
        margin: 0;
        overflow-x: auto;
        font-family: var(--ga-font-mono);
        font-size: var(--ga-text-12);
        color: var(--ga-fg-strong);
        user-select: all;
      }

      /* ── Footer ─────────────────────────────────────── */
      .footer {
        text-align: center;
        font-size: var(--ga-text-12);
        color: var(--ga-fg-dim);
        border-top: 1px solid var(--ga-rule-6);
        padding-top: 24px;
      }

      .footer a {
        color: var(--ga-fg-muted);
        text-decoration: none;
        border-bottom: 1px solid var(--ga-rule-6);
        transition: color 150ms, border-color 150ms;
      }

      .footer a:hover {
        color: var(--ga-fg-strong);
        border-bottom-color: var(--ga-rule-8);
      }

      .copyright {
        margin-top: 12px;
        font-family: var(--ga-font-mono);
        font-size: var(--ga-text-10);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--ga-fg-dimmer);
      }

      /* ── Responsive ─────────────────────────────────── */
      @media (max-width: 480px) {
        .root {
          padding: 40px 16px 60px;
        }
        .logo {
          font-size: 32px;
          margin-bottom: 20px;
        }
        .hero h1 {
          font-size: 24px;
        }
        .download-card {
          padding: 20px 18px;
        }
        .btn {
          flex-direction: column;
          align-items: flex-start;
          gap: 6px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .btn {
          transition: none;
        }
        .footer a {
          transition: none;
        }
      }
    </style>
  </body>
</html>
