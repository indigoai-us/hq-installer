---
import { fetchLatestRelease, formatBytes, formatDate } from "../lib/release.ts";

// Runs on every ISR revalidation (hourly). Rendered HTML is cached by
// Vercel — fresh visitors get a cache hit until the TTL expires.
const release = await fetchLatestRelease();

const aarch64Url = release?.dmgAarch64?.browserDownloadUrl ?? null;
const x64Url = release?.dmgX64?.browserDownloadUrl ?? null;
const aarch64Size = release?.dmgAarch64 ? formatBytes(release.dmgAarch64.size) : null;
const x64Size = release?.dmgX64 ? formatBytes(release.dmgX64.size) : null;
const universalUrl = release?.macUniversal?.asset.browserDownloadUrl ?? null;
const universalSize = release?.macUniversal ? formatBytes(release.macUniversal.asset.size) : null;
const universalFormat = release?.macUniversal?.format ?? null;
// v0.1.11 shipped .dmg; v0.1.12+ ships .zip (Safari auto-extracts, no
// drag-to-Applications). When a universal artifact is present we render
// one primary button instead of the old arch-split pair. The subtitle
// shows the distribution format so users know what they're getting.
const showUniversal = Boolean(universalUrl);
// Format-specific subtitle copy. Each arm stays short enough to fit in
// the secondary slot on mobile (btn-os line, ~36ch).
const universalSubtitle = universalFormat === "zip"
  ? "Universal · Notarized .zip — opens on double-click"
  : universalFormat === "dmg"
    ? "Universal · Notarized .dmg — Apple Silicon + Intel"
    : universalFormat === "app.tar.gz"
      ? "Universal · Notarized .app.tar.gz (advanced)"
      : "Universal · Apple Silicon + Intel";
const releaseDate = release ? formatDate(release.publishedAt) : null;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="HQ — Personal OS for orchestrating work across companies, workers, and AI. Download the native macOS installer." />
    <meta name="theme-color" content="#09090b" />
    <title>HQ — Download</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><text y='50' font-size='48'>HQ</text></svg>" />
    <link rel="canonical" href="https://install.getindigo.ai" />
    <meta property="og:title" content="HQ — Download" />
    <meta property="og:description" content="Personal OS for orchestrating work across companies, workers, and AI." />
    <meta property="og:type" content="website" />

    <!--
      Fonts — JetBrains Mono for display/metadata (matches indigo-marketing
      CTA + terminal type), Inter for body copy. Single stylesheet request
      covers both families.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    />
  </head>
  <body>
    <main class="root">
      <nav class="topbar" aria-label="Indigo">
        <a class="topbar-home" href="https://www.getindigo.ai" aria-label="Indigo home">
          <img
            src="/indigo-logo.svg"
            alt="Indigo"
            width="84"
            height="20"
            decoding="async"
          />
        </a>
        <a class="topbar-link" href="https://www.getindigo.ai/sync">
          HQ Sync →
        </a>
      </nav>

      <header class="hero">
        <div class="prism-beam" aria-hidden="true"></div>
        <div class="logo">
          <span class="logo-mark" data-spectrum-reveal="false">HQ</span>
        </div>
        <h1>Your own personal OS for getting things done.</h1>
        <p class="tagline">
          Orchestrate work across companies, workers, and AI — from one place,
          on your machine, with Claude Code driving.
        </p>
      </header>

      <section class="download-card" aria-labelledby="download-heading">
        <h2 id="download-heading">Download HQ Installer</h2>

        {release ? (
          <div class="release-meta">
            <span class="tag">{release.tag}</span>
            <span class="published">Released {releaseDate}</span>
          </div>
        ) : (
          <div class="release-meta release-meta--pending">
            <span class="tag tag--pending">coming soon</span>
            <span class="published">The first public release is being prepared.</span>
          </div>
        )}

        <div class="buttons" id="buttons">
          {showUniversal ? (
            <a
              id="btn-universal"
              class="btn btn-primary"
              href={universalUrl ?? "#"}
              data-arch="universal"
              aria-disabled={!universalUrl}
              data-state={universalUrl ? "ready" : "pending"}
            >
              <span class="btn-arch">Download for macOS</span>
              <span class="btn-os">{universalSubtitle}</span>
              {universalSize && <span class="btn-size">{universalSize}</span>}
            </a>
          ) : (
            <>
              <a
                id="btn-aarch64"
                class="btn btn-primary"
                href={aarch64Url ?? "#"}
                data-arch="aarch64"
                aria-disabled={!aarch64Url}
                data-state={aarch64Url ? "ready" : "pending"}
              >
                <span class="btn-arch">Apple Silicon</span>
                <span class="btn-os">macOS · M1 / M2 / M3 / M4</span>
                {aarch64Size && <span class="btn-size">{aarch64Size}</span>}
              </a>

              <a
                id="btn-x64"
                class="btn btn-secondary"
                href={x64Url ?? "#"}
                data-arch="x64"
                aria-disabled={!x64Url}
                data-state={x64Url ? "ready" : "pending"}
              >
                <span class="btn-arch">Intel Mac</span>
                <span class="btn-os">macOS · x86_64</span>
                {x64Size && <span class="btn-size">{x64Size}</span>}
              </a>
            </>
          )}
        </div>

        <p class="os-hint" id="os-hint" aria-live="polite"></p>

        <p class="also">
          Also available for:
          <span class="soon">Windows (soon)</span> ·
          <span class="soon">Linux (soon)</span>
        </p>

        <p class="security-note">
          Signed with Indigo's Apple Developer ID and notarized by Apple.
          No Gatekeeper warnings.
        </p>
      </section>

      <section class="devs" aria-labelledby="devs-heading">
        <h3 id="devs-heading">For developers</h3>
        <p>
          Comfortable in a terminal? Skip the installer and bootstrap HQ with
          one command:
        </p>
        <pre class="code"><code>npx create-hq</code></pre>
      </section>

      <footer class="footer">
        <p class="footer-links">
          <a href="https://www.getindigo.ai">Indigo home</a>
          <span class="footer-sep" aria-hidden="true">·</span>
          <a href="https://www.getindigo.ai/sync">Download HQ Sync for macOS</a>
          <span class="footer-sep" aria-hidden="true">·</span>
          {release ? (
            <a href={release.htmlUrl}>Releases on GitHub →</a>
          ) : (
            <a href="https://github.com/indigoai-us/hq-installer">Source on GitHub →</a>
          )}
        </p>
        <p class="copyright">© 2026 Indigo. HQ is open source.</p>
      </footer>
    </main>

    <script is:inline>
      // OS detection — client-side only. Runs after HTML is cached, so
      // ISR doesn't need to re-render per-visitor. We enhance the
      // already-rendered download buttons with an emphasized state +
      // an inline hint above the buttons.
      (function () {
        try {
          const ua = navigator.userAgent || "";
          // navigator.platform is deprecated in the spec but still the
          // only cross-browser path for OS detection on Safari, where
          // navigator.userAgentData does not exist. We keep both.
          /** @type {{ platform?: string }} */
          const nav = /** @type {unknown} */ (navigator);
          const platform = nav.platform || "";

          const isMac = /Mac/i.test(platform) || /Mac/i.test(ua);
          const isWindows = /Win/i.test(platform) || /Windows/i.test(ua);
          const isLinux = /Linux/i.test(platform) || /Linux/i.test(ua);

          // Modern AS Macs report "MacIntel" in platform, but we can
          // still infer Apple Silicon via the "Mac OS X" token in UA
          // combined with a WebKit device memory probe. Browsers try
          // to hide this — fallback is to highlight aarch64 since that's
          // ~80% of new Macs sold and the safer default.
          const isAppleSilicon = (() => {
            if (!isMac) return false;
            // Chrome 91+ ships navigator.userAgentData — arm64 reports
            // architecture "arm" here.
            const uaData = /** @type {{architecture?: string}} */ (
              /** @type {unknown} */ (navigator).userAgentData
            );
            if (uaData && uaData.architecture) {
              return uaData.architecture === "arm";
            }
            // Fallback: default to aarch64 for any Mac newer than 2020.
            return true;
          })();

          const hint = document.getElementById("os-hint");
          const btnA = document.getElementById("btn-aarch64");
          const btnX = document.getElementById("btn-x64");
          const btnU = document.getElementById("btn-universal");

          if (isMac) {
            if (btnU) {
              // Universal build — one button, always featured on Mac.
              btnU.classList.add("btn-featured");
              hint && (hint.textContent = isAppleSilicon
                ? "Detected: macOS on Apple Silicon — this universal build runs natively."
                : "Detected: macOS on Intel — this universal build runs natively.");
            } else if (isAppleSilicon) {
              btnA && btnA.classList.add("btn-featured");
              hint && (hint.textContent = "Detected: macOS on Apple Silicon — the top button is the one you want.");
            } else {
              btnX && btnX.classList.add("btn-featured");
              hint && (hint.textContent = "Detected: macOS on Intel — use the Intel Mac button.");
            }
          } else if (isWindows) {
            hint && (hint.textContent = "Detected: Windows. Native installer coming soon — for now, try npx create-hq.");
            btnA && btnA.classList.add("btn-dim");
            btnX && btnX.classList.add("btn-dim");
            btnU && btnU.classList.add("btn-dim");
          } else if (isLinux) {
            hint && (hint.textContent = "Detected: Linux. Native installer coming soon — for now, try npx create-hq.");
            btnA && btnA.classList.add("btn-dim");
            btnX && btnX.classList.add("btn-dim");
            btnU && btnU.classList.add("btn-dim");
          }
        } catch {
          // Silently no-op on any runtime error — the static HTML still
          // works fine without JS.
        }
      })();
    </script>

    <!--
      Pack assets — copied from
      knowledge/public/design-styles/packs/hq-cinematic/{tokens,keyframes}.css
      Do not symlink across repo boundaries (Vercel build constraint).
    -->
    <style>@import "../styles/hq-cinematic-tokens.css";</style>
    <style>@import "../styles/hq-cinematic-keyframes.css";</style>

    <style>
      /* ──────────────────────────────────────────────────────────────
         hq-installer download page — hq-cinematic consumer
         Navy-void background. One prism beam behind the hero carries
         chroma (not surfaces). Warm-neutral hairlines. Inter 800/900
         display. Honors prefers-reduced-motion via the pack's keyframes.
         ────────────────────────────────────────────────────────────── */

      * {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg-navy-500);
        color: rgba(255, 255, 255, 0.88);
        font-family: "Inter", system-ui, -apple-system, sans-serif;
        font-size: 14.5px;
        letter-spacing: 0.005em;
        -webkit-font-smoothing: antialiased;
        /* Subtle vignette — deepest navy at the corners, mid navy in the
           center. Pack "CrtVignette" primitive in CSS form (no component
           dependency). Keeps focus on the download card. */
        background-image: radial-gradient(
          ellipse at center,
          var(--bg-navy-400) 0%,
          var(--bg-navy-600) 60%,
          var(--bg-navy-900) 100%
        );
        background-attachment: fixed;
        min-height: 100vh;
      }

      /* Focus rings — keyboard a11y floor, quality-gate item.
         Warm-yellow against navy ≈ 11.9:1 (AAA). */
      a:focus-visible,
      button:focus-visible,
      [tabindex]:focus-visible {
        outline: 1px solid var(--warm-yellow);
        outline-offset: 2px;
      }

      .root {
        max-width: 640px;
        margin: 0 auto;
        padding: 28px 24px 80px;
        position: relative;
      }

      /* ── Topbar ─────────────────────────────────────── */
      /* Indigo logo (home link) on the left, secondary /sync link on
         the right. Thin and unobtrusive — the HQ hero is still the
         focal point below. */
      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 44px;
        position: relative;
        z-index: 2;
      }

      .topbar-home {
        display: inline-flex;
        align-items: center;
        opacity: 0.85;
        transition: opacity 200ms var(--motion-ease-cinematic);
      }

      .topbar-home:hover {
        opacity: 1;
      }

      .topbar-home img {
        display: block;
        height: 20px;
        width: auto;
        /* Source SVG is near-black (#141414). Invert to white so it reads
           on the navy background. brightness(0) flattens to black first so
           invert(1) produces pure white regardless of original paint. */
        filter: brightness(0) invert(1);
      }

      .topbar-link {
        font-family: var(--font-display);
        font-variant-numeric: tabular-nums;
        font-size: 12px;
        letter-spacing: 0.04em;
        color: var(--warm-yellow-80);
        text-decoration: none;
        padding: 6px 12px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 999px;
        transition:
          color 200ms var(--motion-ease-cinematic),
          border-color 200ms var(--motion-ease-cinematic),
          background 200ms var(--motion-ease-cinematic);
      }

      .topbar-link:hover {
        color: #fafafa;
        border-color: rgba(255, 255, 255, 0.25);
        background: rgba(255, 255, 255, 0.04);
      }

      /* ── Hero ───────────────────────────────────────── */
      .hero {
        text-align: center;
        margin-bottom: 56px;
        position: relative;
        isolation: isolate;
      }

      /* Single prism beam behind the wordmark. Pack rule: "reserve the
         full spectrum gradient for one or two hero moments per screen."
         This is the one for this page — everything else uses warm
         neutrals or a single accent hue. */
      .prism-beam {
        position: absolute;
        inset: -40px -20% auto -20%;
        height: 220px;
        background: var(--gradient-spectrum-linear);
        filter: blur(48px);
        opacity: 0.38;
        z-index: -1;
        pointer-events: none;
        transform-origin: 50% 50%;
        animation: beam-drift var(--motion-duration-drift)
          var(--motion-ease-drift) infinite alternate;
      }

      /* Logo — Inter 900, spectrum gradient text mask. */
      .logo {
        margin-bottom: 28px;
        line-height: 1;
      }

      .logo-mark {
        display: inline-block;
        font-family: var(--font-display);
        font-weight: var(--font-display-weight-black);
        font-size: 72px;
        letter-spacing: -0.02em;
        text-transform: uppercase;
        background: var(--gradient-spectrum-linear);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        -webkit-text-fill-color: transparent;
        /* Headline reveal — one-shot prism sweep across the mark.
           Pack keyframes use background-position, which matches our
           gradient text mask cleanly. */
        background-size: 200% 100%;
        /* Pack's `prism-sweep` ends at opacity:0 (designed for transient
           reveals layered over a static fallback). Local override settles
           the wordmark visible after the sweep completes. */
        animation: prism-sweep-settle var(--motion-duration-sweep)
          var(--motion-ease-cinematic) both;
        animation-delay: 120ms;
      }

      @keyframes prism-sweep-settle {
        0% {
          background-position: -120% 0;
          opacity: 0;
        }
        20% {
          opacity: 1;
        }
        100% {
          background-position: 100% 0;
          opacity: 1;
        }
      }

      /* Solid-color fallback already handled by
         hq-cinematic-keyframes.css `@supports not (background-clip: text)` */

      .hero h1 {
        font-family: "Inter", system-ui, -apple-system, sans-serif;
        font-weight: 600;
        font-size: 34px;
        line-height: 1.15;
        margin: 0 0 16px;
        letter-spacing: -0.015em;
        color: rgba(255, 255, 255, 0.96);
      }

      .tagline {
        font-size: 15px;
        color: var(--warm-yellow-80);
        line-height: 1.6;
        margin: 0 auto;
        max-width: 520px;
      }

      /* ── Download card ──────────────────────────────── */
      /* Transparent, warm-yellow hairline — counterweight to the
         navy + spectrum hero. Pack rule: "pair spectrum accents with
         warm-neutral hairlines and glyphs for counterweight." */
      .download-card {
        position: relative;
        background: rgba(10, 18, 40, 0.45); /* bg-navy-100 @ 45% — subtle lift */
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
        border: 1px solid var(--warm-yellow-40);
        border-radius: 2px;
        padding: 28px 24px 24px;
        margin-bottom: 28px;
      }

      .download-card h2 {
        font-family: var(--font-display);
        font-size: 10px;
        font-weight: var(--font-display-weight-bold);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--warm-yellow-80);
        margin: 0 0 18px;
      }

      .release-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 22px;
        font-size: 12px;
        color: var(--warm-yellow-80);
      }

      /* Status badges — ready (spectrum-gold) / pending (warm-pink).
         Tabular nums, slight uppercase affectation. */
      .tag {
        display: inline-flex;
        align-items: center;
        padding: 3px 8px;
        border-radius: 2px;
        background: rgba(129, 140, 248, 0.08);
        color: var(--spectrum-violet);
        border: 1px solid rgba(129, 140, 248, 0.3);
        font-family: var(--font-display);
        font-variant-numeric: tabular-nums;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .tag--pending {
        background: rgba(169, 119, 145, 0.12);
        color: var(--warm-pink);
        border-color: var(--warm-pink-40);
      }

      .published {
        font-family: var(--font-display);
        font-variant-numeric: tabular-nums;
        font-size: 11px;
        color: var(--warm-yellow-60);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      /* ── Buttons ────────────────────────────────────── */
      .buttons {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .btn {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px 20px;
        border: 1px solid var(--warm-yellow-40);
        border-radius: 2px;
        text-decoration: none;
        color: rgba(255, 255, 255, 0.92);
        background: rgba(14, 23, 51, 0.55); /* bg-navy-000 @ 55% */
        transition:
          background 200ms var(--motion-ease-cinematic),
          border-color 200ms var(--motion-ease-cinematic),
          box-shadow 200ms var(--motion-ease-cinematic);
        position: relative;
      }

      .btn:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.25);
        box-shadow:
          0 0 0 1px rgba(255, 255, 255, 0.06),
          0 8px 32px -12px rgba(129, 140, 248, 0.25);
      }

      .btn[aria-disabled="true"] {
        opacity: 0.35;
        pointer-events: none;
      }

      /* Featured state (OS-detection match) — bloom pulse + spectrum
         rim. Pack's bloom-pulse keyframe is single-shot; we replay it
         on focus-visible and as a one-time entrance. Rim uses a thin
         spectrum gradient border (no colored drop shadow). */
      /* Featured state (OS-detection match) — primary CTA, white fill.
         Per indigo-marketing brand rule (2026-04-24): primary CTAs are
         white, not periwinkle. Matches the "Learn HQ" / "Download .dmg"
         pattern on www.getindigo.ai. */
      .btn-featured {
        border-color: var(--spectrum-gold);
        background: var(--spectrum-gold);
        color: var(--bg-navy-500);
        box-shadow:
          0 0 24px -6px rgba(255, 255, 255, 0.5),
          0 12px 40px -16px rgba(255, 255, 255, 0.25);
      }

      .btn-featured:hover {
        background: #ffffff;
        border-color: #ffffff;
        box-shadow:
          0 0 32px -4px rgba(255, 255, 255, 0.7),
          0 12px 40px -16px rgba(255, 255, 255, 0.3);
      }

      .btn-featured .btn-arch,
      .btn-featured .btn-os,
      .btn-featured .btn-size {
        color: var(--bg-navy-500);
      }

      .btn-featured:focus-visible {
        animation: bloom-pulse var(--motion-duration-bloom)
          var(--motion-ease-cinematic) both;
      }

      .btn-dim {
        opacity: 0.45;
      }

      .btn-arch {
        font-family: var(--font-display);
        font-weight: var(--font-display-weight-bold);
        font-size: 15px;
        letter-spacing: 0.01em;
        flex: 1;
      }

      .btn-os {
        font-size: 12px;
        color: var(--warm-yellow-80);
      }

      .btn-size {
        font-family: var(--font-display);
        font-variant-numeric: tabular-nums;
        font-size: 11px;
        color: var(--warm-yellow-60);
        letter-spacing: 0.02em;
      }

      .os-hint {
        margin: 18px 0 0;
        font-size: 12px;
        color: var(--warm-yellow-80);
        min-height: 18px;
      }

      .also {
        margin: 24px 0 8px;
        font-size: 12px;
        color: var(--warm-yellow-80);
      }

      .soon {
        color: var(--warm-yellow-60);
        font-family: var(--font-display);
        font-variant-numeric: tabular-nums;
        font-size: 11px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .security-note {
        margin: 16px 0 0;
        font-size: 12px;
        color: var(--warm-yellow-80);
        line-height: 1.55;
      }

      /* ── Dev path ───────────────────────────────────── */
      .devs {
        position: relative;
        background: rgba(10, 18, 40, 0.35);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        border: 1px solid var(--warm-brown-60);
        border-radius: 2px;
        padding: 22px 22px;
        margin-bottom: 48px;
      }

      .devs h3 {
        font-family: var(--font-display);
        font-size: 10px;
        font-weight: var(--font-display-weight-bold);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--warm-yellow-80);
        margin: 0 0 14px;
      }

      .devs p {
        margin: 0 0 14px;
        font-size: 14px;
        color: var(--warm-yellow-80);
        line-height: 1.6;
      }

      .code {
        background: var(--bg-navy-900);
        border: 1px solid var(--warm-brown-60);
        border-radius: 2px;
        padding: 12px 14px;
        margin: 0;
        overflow-x: auto;
        font-family: var(--font-display);
        font-variant-numeric: tabular-nums;
        font-size: 13px;
        color: var(--spectrum-cyan);
        user-select: all;
      }

      /* ── Footer ─────────────────────────────────────── */
      .footer {
        text-align: center;
        font-size: 12px;
        color: var(--warm-yellow-60);
        border-top: 1px solid var(--warm-brown-60);
        padding-top: 28px;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin: 0;
      }

      .footer-sep {
        color: var(--warm-yellow-60);
        opacity: 0.5;
      }

      .footer a {
        color: var(--warm-yellow-80);
        text-decoration: none;
        border-bottom: 1px solid var(--warm-yellow-40);
        transition:
          color 200ms var(--motion-ease-cinematic),
          border-color 200ms var(--motion-ease-cinematic);
      }

      .footer a:hover {
        color: var(--spectrum-gold);
        border-bottom-color: var(--spectrum-gold);
      }

      .copyright {
        margin-top: 14px;
        font-family: var(--font-display);
        font-variant-numeric: tabular-nums;
        font-size: 10px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--warm-yellow-60);
      }

      /* ── Responsive ─────────────────────────────────── */
      @media (max-width: 480px) {
        .root {
          padding: 40px 16px 60px;
        }
        .logo-mark {
          font-size: 56px;
        }
        .hero h1 {
          font-size: 26px;
        }
        .download-card {
          padding: 22px 18px 20px;
        }
        .btn {
          flex-direction: column;
          align-items: flex-start;
          gap: 6px;
          padding: 16px;
        }
        .prism-beam {
          height: 180px;
          opacity: 0.3;
        }
      }

      /* Reduced motion — stop the beam drift and the intro sweep.
         Pack's keyframes.css already collapses animations to
         end-state; we additionally skip the sweep entirely so the
         wordmark renders with a static gradient (no mid-animation
         background-position glitch). */
      @media (prefers-reduced-motion: reduce) {
        .prism-beam {
          animation: none;
          opacity: 0.28;
        }
        .logo-mark {
          animation: none;
          background-position: 50% 0;
        }
        .btn,
        .footer a {
          transition: none;
        }
      }
    </style>
  </body>
</html>
